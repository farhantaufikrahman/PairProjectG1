<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 32px 16px; }
    .register-card { border-radius: 20px; box-shadow: 0 4px 24px rgba(0,0,0,0.10); border: none; width: 100%; max-width: 480px; }
    .register-header { background-color: #212529; border-radius: 20px 20px 0 0; padding: 32px; text-align: center; }
    .register-header h1 { color: #fff; font-size: 22px; font-weight: 700; margin: 0; }
    .register-header p { color: #adb5bd; font-size: 13px; margin: 6px 0 0; }
    .logo-icon { font-size: 34px; color: #fff; margin-bottom: 10px; }
    .register-body { padding: 32px; }
    .form-label { font-size: 13px; font-weight: 600; color: #495057; text-transform: uppercase; letter-spacing: 0.5px; }
    .form-control, .form-select { border-radius: 10px; padding: 10px 14px; font-size: 15px; border: 1.5px solid #dee2e6; }
    .form-control:focus, .form-select:focus { border-color: #212529; box-shadow: 0 0 0 3px rgba(33,37,41,0.1); }
    .input-group-text { border-radius: 10px 0 0 10px; background-color: #f8f9fa; border: 1.5px solid #dee2e6; border-right: none; color: #6c757d; }
    .input-group .form-control, .input-group .form-select { border-radius: 0 10px 10px 0; border-left: none; }
    .btn-toggle-pw { border-radius: 0 10px 10px 0 !important; border: 1.5px solid #dee2e6; border-left: none; background: #f8f9fa; color: #6c757d; }
    .btn-toggle-pw:hover { background: #e9ecef; color: #212529; }
    .btn-submit { border-radius: 10px; padding: 12px; font-weight: 600; font-size: 15px; }
    .preview-box { width: 100%; height: 160px; border-radius: 10px; border: 2px dashed #dee2e6; display: flex; align-items: center; justify-content: center; background: #f8f9fa; overflow: hidden; transition: border-color 0.2s; margin-top: 10px; }
    .preview-box img { width: 100%; height: 100%; object-fit: cover; border-radius: 8px; display: none; }
    .preview-placeholder { text-align: center; color: #adb5bd; }
    .preview-placeholder i { font-size: 32px; display: block; margin-bottom: 4px; }
    .role-option { border: 1.5px solid #dee2e6; border-radius: 10px; padding: 12px 16px; cursor: pointer; transition: all 0.2s; }
    .role-option:has(input:checked) { border-color: #212529; background-color: #f1f3f5; }
    .role-option input { accent-color: #212529; }
    .login-link { font-size: 13px; text-align: center; color: #6c757d; margin-top: 20px; }
    .login-link a { color: #212529; font-weight: 600; text-decoration: none; }
    .login-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>

<div class="register-card card">


  <div class="register-header">
    <div class="logo-icon"></div>
    <h1>Buat Akun Baru</h1>
    <p>Daftar sekarang dan mulai belanja atau berjualan</p>
  </div>


  <div class="register-body">
    <form action="/register" method="POST">

 
      <div class="mb-3">
     <% if(errors){ %>
              <% errors=errors.split(',') %>
            <% errors.forEach(el => { %>
             <label class="form-label" style="color: red; text-align: center;"><%= el %></label>
            <% })} %>
        <label class="form-label">Email</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-envelope"></i></span>
          <input type="email" name="email" class="form-control" placeholder="contoh@email.com" >
        </div>
      </div>


      <div class="mb-3">
        <label class="form-label">Password</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-lock"></i></span>
          <input type="password" name="password" id="passwordInput" class="form-control" placeholder="Buat password" >
          <button type="button" class="btn btn-toggle-pw" id="togglePw" tabindex="-1">
            <i class="bi bi-eye" id="toggleIcon"></i>
          </button>
        </div>
      </div>


      <div class="mb-3">
        <label class="form-label">Nama Lengkap</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-person"></i></span>
          <input type="text" name="fullName" class="form-control" placeholder="Nama lengkap kamu">
        </div>
      </div>

  
      <div class="mb-3">
        <label class="form-label">Nomor Telepon</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-telephone"></i></span>
          <input type="tel" name="phoneNumber" class="form-control" placeholder="08xxxxxxxxxx" >
        </div>
      </div>


      <div class="mb-3">
        <label class="form-label">Alamat</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-geo-alt"></i></span>
          <input type="text" name="address" class="form-control" placeholder="Alamat lengkap kamu" >
        </div>
      </div>

            <div class="mb-3">
        <label class="form-label">Image</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-file-image"></i></span>
          <input type="text" name="image" class="form-control" placeholder="URL Foto Kamu" >
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Daftar Sebagai</label>
        <div class="d-flex gap-3">
          <label class="role-option d-flex align-items-center gap-2 flex-fill">
            <input type="radio" name="role" value="buyer" >
            <div>
              <div style="font-weight:600; font-size:14px;">Buyer</div>
              <div style="font-size:12px; color:#6c757d;">Belanja produk</div>
            </div>
          </label>
          <label class="role-option d-flex align-items-center gap-2 flex-fill">
            <input type="radio" name="role" value="seller">
            <div>
              <div style="font-weight:600; font-size:14px;"></i>Seller</div>
              <div style="font-size:12px; color:#6c757d;">Jual produk</div>
            </div>
          </label>
        </div>
      </div>

  

      <div class="d-grid">
        <button type="submit" class="btn btn-dark btn-submit">
          <i class="bi bi-person-plus me-2"></i>Daftar Sekarang
        </button>
      </div>

    </form>

 
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>