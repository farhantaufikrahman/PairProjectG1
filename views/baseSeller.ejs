<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Seller Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; }
    .navbar-brand { font-weight: 700; }
    .card-table { border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .table thead th { background-color: #212529; color: #fff; font-weight: 500; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; border: none; }
    .table tbody tr { vertical-align: middle; }
    .table tbody tr:hover { background-color: #f8f9fa; }
    .product-img { width: 70px; height: 70px; object-fit: cover; border-radius: 8px; border: 1px solid #dee2e6; }
    .price-text { font-weight: 600; color: #198754; font-size: 14px; }
    .btn-action { font-size: 13px; padding: 5px 14px; border-radius: 20px; }
    .empty-state { padding: 60px 20px; text-align: center; color: #adb5bd; }
    .empty-state i { font-size: 52px; margin-bottom: 12px; display: block; }
    .stat-card { border-radius: 12px; border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
    .stat-label { font-size: 12px; text-transform: uppercase; letter-spacing: 0.6px; color: #adb5bd; font-weight: 500; }
    .stat-value { font-size: 26px; font-weight: 700; color: #212529; }
  </style>
</head>
<body>

<nav class="navbar navbar-dark bg-dark px-4 py-3 mb-4">
  <span class="navbar-brand">
    <i class="bi bi-shop me-2"></i>Seller Dashboard
  </span>
  <div class="ms-auto d-flex gap-2">
    <a href="/seller/<%= usId %>/showProfile" class="btn btn-outline-light btn-sm">
      <i class="bi bi-person-circle me-1"></i>Profil Saya
    </a>
    <a href="/seller/<%= usId %>/addProduct" class="btn btn-warning btn-sm fw-semibold">
      <i class="bi bi-plus-lg me-1"></i>Tambah Produk
    </a>
     <a  href="/" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-in-left"></i>Logout</a>
  </div>
</nav>

<div class="container pb-5">

  <div class="mb-4">
    <h1 class="fw-bold mb-1" style="font-size:22px;">Produk Saya</h1>

  </div>



  <div class="card card-table border-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th style="width:80px">Foto</th>
          <th>Nama Produk</th>
          <th>Harga</th>
          <th>Stok</th>
          <th class="text-center">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (data.length === 0) { %>
          <tr>
            <td colspan="5">
              <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <p class="fw-semibold mb-1">Belum ada produk</p>
                <p class="text-muted" style="font-size:13px;">Mulai tambahkan produk pertamamu!</p>
                <a href="/seller/<%= usId %>/addProduct" class="btn btn-dark btn-sm mt-2">
                  <i class="bi bi-plus-lg me-1"></i>Tambah Produk
                </a>
              </div>
            </td>
          </tr>
        <% } else { %>
          <% data.forEach(el => { %>
          <tr>
            <td>
              <img src="<%= el.imageUrl %>" class="product-img" alt="<%= el.name %>">
            </td>
            <td>
              <div class="fw-semibold"><%= el.name %></div>
            </td>
            <td>
              <span class="price-text"><%= formatRupiah(el.price) %></span>
            </td>
            <td>
              <% if (el.stock === 0) { %>
                <span class="badge bg-danger-subtle text-danger" style="font-size:12px;">Habis</span>
              <% } else if (el.stock <= 5) { %>
                <span class="badge bg-warning-subtle text-warning" style="font-size:12px;"><%= el.stock %> pcs</span>
              <% } else { %>
                <span class="badge bg-success-subtle text-success" style="font-size:12px;"><%= el.stock %> pcs</span>
              <% } %>
            </td>
            <td class="text-center">
              <div class="d-flex gap-2 justify-content-center">
                <a href="/seller/<%= usId %>/edtProduct/<%= el.id %>" class="btn btn-outline-primary btn-action">
                  <i class="bi bi-pencil me-1"></i>Edit
                </a>
                <a href="/seller/<%= usId %>/delProduct/<%= el.id %>" class="btn btn-outline-danger btn-action"
                   onclick="return confirm('Yakin ingin menghapus produk ini?')">
                  <i class="bi bi-trash3 me-1"></i>Hapus
                </a>
              </div>
            </td>
          </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>