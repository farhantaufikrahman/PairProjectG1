<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Buyer - Toko Online</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; }
    .navbar-brand { font-weight: 700; letter-spacing: 0.5px; }
    .search-wrapper { max-width: 480px; }
    .product-img { width: 70px; height: 70px; object-fit: cover; border-radius: 8px; border: 1px solid #dee2e6; }
    .table thead th { background-color: #212529; color: #fff; font-weight: 500; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; border: none; }
    .table tbody tr { vertical-align: middle; }
    .table tbody tr:hover { background-color: #f1f3f5; }
    .badge-price { font-size: 14px; font-weight: 600; color: #198754; }
    .badge-stock { font-size: 12px; }
    .btn-addcart { font-size: 13px; padding: 6px 16px; border-radius: 20px; }
    .seller-id { font-size: 12px; color: #6c757d; font-family: monospace; }
    .section-title { font-weight: 700; font-size: 22px; }
    .card-table { border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .empty-state { padding: 60px 20px; text-align: center; color: #adb5bd; }
    .empty-state i { font-size: 48px; margin-bottom: 12px; display: block; }
  </style>
</head>
<body>

<%
  function stockBadge(stock) {
    if (stock > 10) return 'bg-success-subtle text-success';
    if (stock > 3) return 'bg-warning-subtle text-warning';
    return 'bg-danger-subtle text-danger';
  }
%>


<nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4 py-3 mb-4">
  <span class="navbar-brand">
    <i class="bi bi-shop me-2"></i>Hewan Ternak Online
  </span>
  <div class="ms-auto">
    <a href="/buyer/<%= buyerId %>/showProfile" class="btn btn-outline-light btn-sm">
      <i class="bi bi-person-circle me-1"></i>Profil Saya
    </a>
    <a  href="/" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-in-left"></i>   Logout</a>
  </div>
</nav>

<div class="container pb-5">


  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
      <h1 class="section-title mb-0">Daftar Produk</h1>
   
    </div>
    <form action="" method="GET" class="search-wrapper d-flex gap-2">
      <input type="hidden" name="buyerId" value="<%= buyerId %>">
      <div class="input-group">
        <span class="input-group-text bg-white">
          <i class="bi bi-search text-muted"></i>
        </span>
        <input
          type="text"
          name="search"
          class="form-control border-start-0 ps-0"
          placeholder="Cari nama produk..."
          value="<%= search || '' %>"
        >
        <button type="submit" class="btn btn-dark px-3">Cari</button>
      </div>
    </form>
  </div>

  <div class="card card-table border-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th style="width:80px">Foto</th>
          <th>Nama Produk</th>
          <th>Harga</th>
          <th>Stok</th>
        
          <th class="text-center">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (product && product.length > 0) { %>
          <% product.forEach(el => { %>
            <tr>
              <td>
                <img src="<%= el.imageUrl %>" class="product-img" alt="<%= el.name %>">
              </td>
              <td>
                <div class="fw-semibold"><%= el.name %></div>
              </td>
              <td>
                <span class="badge-price"><%= formatRupiah(el.price) %></span>
              </td>
              <td>
                <span class="badge <%= stockBadge(el.stock) %> badge-stock">
                  <%= el.stock %> pcs
                </span>
              </td>
            
              <td class="text-center">
                <form action="/buyer/cart/<%= buyerId %>" method="POST">
                  <input type="hidden" name="productId" value="<%= el.id %>">
                  <input type="hidden" name="action" value="addcart">
                  <button type="submit" class="btn btn-outline-dark btn-addcart">
                    <i class="bi bi-cart-plus me-1"></i>Tambah
                  </button>
                </form>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="6">
              <div class="empty-state">
                <i class="bi bi-box-seam"></i>
                <p class="mb-0 fw-semibold">Produk tidak ditemukan</p>
                <p class="text-muted" style="font-size:13px;">Coba kata kunci yang berbeda</p>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
