<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-card { border-radius: 20px; box-shadow: 0 4px 24px rgba(0,0,0,0.10); border: none; width: 100%; max-width: 420px; }
    .login-header { background-color: #212529; border-radius: 20px 20px 0 0; padding: 36px 32px 28px; text-align: center; }
    .login-header h1 { color: #fff; font-size: 22px; font-weight: 700; margin: 0; }
    .login-header p { color: #adb5bd; font-size: 13px; margin: 6px 0 0; }
    .login-body { padding: 32px; }
    .form-label { font-size: 13px; font-weight: 600; color: #495057; text-transform: uppercase; letter-spacing: 0.5px; }
    .form-control { border-radius: 10px; padding: 10px 14px; font-size: 15px; border: 1.5px solid #dee2e6; }
    .form-control:focus { border-color: #212529; box-shadow: 0 0 0 3px rgba(33,37,41,0.1); }
    .input-group-text { border-radius: 10px 0 0 10px; background-color: #f8f9fa; border: 1.5px solid #dee2e6; border-right: none; color: #6c757d; }
    .input-group .form-control { border-radius: 0 10px 10px 0; border-left: none; }
    .btn-toggle-pw { border-radius: 0 10px 10px 0 !important; border: 1.5px solid #dee2e6; border-left: none; background: #f8f9fa; color: #6c757d; }
    .btn-toggle-pw:hover { background: #e9ecef; color: #212529; }
    .btn-login { border-radius: 10px; padding: 12px; font-weight: 600; font-size: 15px; }
    .divider { border-top: 1px solid #dee2e6; margin: 20px 0; }
    .logo-icon { font-size: 36px; color: #fff; margin-bottom: 10px; }
  </style>
</head>
<body>

<div class="login-card card">


  <div class="login-header">
  
    <h1>Toko Online</h1>
    <p>Masuk ke akunmu untuk melanjutkan</p>
  </div>


  <div class="login-body">
    <form action="/logIn" method="POST">
    <% if(errors){ %>
              <% errors=errors.split(',') %>
            <% errors.forEach(el => { %>
             <label class="form-label" style="color: red; text-align: center;"><%= el %></label>
            <% })} %>
  
      <div class="mb-4">

        <label class="form-label">Email</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-envelope"></i></span>
          <input
            type="email"
            name="email"
            class="form-control"
            placeholder="contoh@email.com">
        </div>
      </div>

  
      <div class="mb-4">
        <label class="form-label">Password</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-lock"></i></span>
          <input
            type="password"
            name="password"
            id="passwordInput"
            class="form-control"
            placeholder="Masukkan password"
>
          <button type="button" class="btn btn-toggle-pw" id="togglePw" tabindex="-1">
            <i class="bi bi-eye" id="toggleIcon"></i>
          </button>
        </div>
      </div>


      <div class="d-grid mt-2">
        <button type="submit" class="btn btn-dark btn-login">
          <i class="bi bi-box-arrow-in-right me-2"></i>Login
        </button>
      </div>

    </form>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>