<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .welcome-card { border-radius: 24px; box-shadow: 0 4px 32px rgba(0,0,0,0.10); border: none; width: 100%; max-width: 440px; overflow: hidden; }
    .welcome-header { background-color: #212529; padding: 48px 32px 40px; text-align: center; }
    .welcome-header h1 { color: #fff; font-size: 26px; font-weight: 700; margin: 0 0 8px; }
    .welcome-header p { color: #adb5bd; font-size: 14px; margin: 0; line-height: 1.6; }
    .logo-icon { font-size: 48px; color: #fff; margin-bottom: 16px; }
    .welcome-body { padding: 36px 32px; background: #fff; }
    .btn-register { border-radius: 10px; padding: 13px; font-weight: 600; font-size: 15px; }
    .btn-login { border-radius: 10px; padding: 13px; font-weight: 600; font-size: 15px; }
    .divider-text { font-size: 12px; color: #adb5bd; text-align: center; margin: 16px 0; position: relative; }
    .divider-text::before, .divider-text::after { content: ''; position: absolute; top: 50%; width: 42%; height: 1px; background: #dee2e6; }
    .divider-text::before { left: 0; }
    .divider-text::after { right: 0; }
    .feature-list { list-style: none; padding: 0; margin: 0 0 28px; }
    .feature-list li { font-size: 13px; color: #6c757d; padding: 5px 0; display: flex; align-items: center; gap: 8px; }
    .feature-list li i { color: #212529; font-size: 15px; }
  </style>
</head>
<body>
 
<div class="welcome-card card">
 

  <div class="welcome-header">
    <div class="logo-icon"></div>
    <h1>Selamat Datang!</h1>
    <p>Platform belanja & jualan Hewan Perternakan online</p>
  </div>
 

  <div class="welcome-body">
 
  
 
    <div class="d-grid gap-3">
      <a href="/register" class="btn btn-dark btn-register">
        <i class="bi bi-person-plus me-2"></i>Daftar Akun Baru
      </a>
      <div class="divider-text">atau</div>
      <a href="/logIn" class="btn btn-outline-dark btn-login">
        <i class="bi bi-box-arrow-in-right me-2"></i>Masuk ke Akun
      </a>
    </div>
 
  </div>
 
</div>
 
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>