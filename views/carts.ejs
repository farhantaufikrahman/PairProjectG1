<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Keranjang Belanja</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; }
    .navbar-brand { font-weight: 700; }
    .card-table { border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .table thead th { background-color: #212529; color: #fff; font-weight: 500; font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; border: none; }
    .table tbody tr { vertical-align: middle; }
    .table tbody tr:hover { background-color: #f8f9fa; }
    .product-img { width: 70px; height: 70px; object-fit: cover; border-radius: 8px; border: 1px solid #dee2e6; }
    .qty-wrapper { display: flex; align-items: center; gap: 6px; justify-content: center; }
    .qty-btn { width: 30px; height: 30px; padding: 0; border-radius: 50%; font-size: 16px; line-height: 1; display: flex; align-items: center; justify-content: center; }
    .qty-display { min-width: 28px; text-align: center; font-weight: 600; font-size: 15px; }
    .subtotal-text { font-weight: 600; color: #198754; font-size: 14px; }
    .btn-hapus { font-size: 13px; padding: 5px 14px; border-radius: 20px; }
    .summary-card { border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .total-label { font-size: 13px; color: #6c757d; }
    .total-value { font-size: 24px; font-weight: 700; color: #212529; }
    .btn-checkout { border-radius: 10px; padding: 12px; font-weight: 600; font-size: 15px; }
    .empty-state { padding: 60px 20px; text-align: center; color: #adb5bd; }
    .empty-state i { font-size: 52px; margin-bottom: 12px; display: block; }
  </style>
</head>
<body>


<nav class="navbar navbar-dark bg-dark px-4 py-3 mb-4">
  <span class="navbar-brand">
    <i class="bi bi-shop me-2"></i>Hewan Ternak Online
  </span>
  <div class="ms-auto">
    <a href="/buyer/<%= buyerId %>" class="btn btn-outline-light btn-sm">
      <i class="bi bi-arrow-left me-1"></i>Lanjut Belanja
    </a>
  </div>
</nav>

<div class="container pb-5">
  <div class="mb-4">
    <h1 class="fw-bold mb-0" style="font-size:22px;">
      <i class="bi bi-cart3 me-2"></i>Keranjang Belanja
    </h1>
  
  </div>

  <div class="row g-4 align-items-start">

    <div class="col-lg-8">
      <div class="card card-table border-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th style="width:80px">Foto</th>
              <th>Produk</th>
              <th class="text-center">Stok</th>
              <th class="text-center">Jumlah</th>
              <th class="text-center">Subtotal</th>
              <th class="text-center">Hapus</th>
            </tr>
          </thead>
          <tbody>
            <% if (carts.length === 0) { %>
              <tr>
                <td colspan="6">
                  <div class="empty-state">
                    <i class="bi bi-cart-x"></i>
                    <p class="fw-semibold mb-1">Keranjang kamu kosong</p>
                    <p class="text-muted" style="font-size:13px;">Yuk, mulai belanja sekarang!</p>
                    <a href="/buyer/<%= buyerId %>" class="btn btn-dark btn-sm mt-2">
                      <i class="bi bi-bag me-1"></i>Belanja Sekarang
                    </a>
                  </div>
                </td>
              </tr>
            <% } else { %>
              <% carts.forEach(item => { %>
              <tr>
                <td>
                  <img src="<%= item.Product.imageUrl %>" class="product-img" alt="<%= item.Product.name %>">
                </td>
                <td>
                  <div class="fw-semibold"><%= item.Product.name %></div>
                </td>
                <td class="text-center">
                  <span class="badge bg-secondary-subtle text-secondary" style="font-size:12px;">
                    <%= item.Product.stock %> pcs
                  </span>
                </td>
                <td class="text-center">
                  <div class="qty-wrapper">
                    <form action="/buyer/cart/<%= buyerId %>" method="POST">
                      <input type="hidden" name="productId" value="<%= item.Product.id %>">
                      <input type="hidden" name="action" value="decrement">
                      <button type="submit" class="btn btn-outline-secondary qty-btn">
                        <i class="bi bi-dash"></i>
                      </button>
                    </form>
                    <span class="qty-display"><%= item.quantity %></span>
                    <form action="/buyer/cart/<%= buyerId %>" method="POST">
                      <input type="hidden" name="productId" value="<%= item.Product.id %>">
                      <input type="hidden" name="action" value="increment">
                      <button type="submit" class="btn btn-outline-dark qty-btn">
                        <i class="bi bi-plus"></i>
                      </button>
                    </form>
                  </div>
                </td>
                <td class="text-center">
                  <span class="subtotal-text"><%= formatRupiah(item.getCartSubtotal()) %></span>
                </td>
                <td class="text-center">
                  <form action="/buyer/cart/<%= buyerId %>" method="POST">
                    <input type="hidden" name="productId" value="<%= item.Product.id %>">
                    <input type="hidden" name="action" value="delete">
                    <button type="submit" class="btn btn-outline-danger btn-hapus">
                      <i class="bi bi-trash3"></i>
                    </button>
                  </form>
                </td>
              </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  
    <div class="col-lg-4">
      <div class="card summary-card border-0 p-4">
        <h6 class="fw-bold text-uppercase text-muted mb-3" style="font-size:12px; letter-spacing:0.8px;">
          Ringkasan Pesanan
        </h6>

        <div class="d-flex justify-content-between align-items-center mb-2">
          <span class="text-muted" style="font-size:14px;">Subtotal (<%= carts.length %> item)</span>
          <span style="font-size:14px; font-weight:500;"><%= formatRupiah(total) %></span>
        </div>
    

        <hr class="my-2">

        <div class="d-flex justify-content-between align-items-center mb-4">
          <span class="total-label fw-semibold">Total Pembayaran</span>
          <span class="total-value"><%= formatRupiah(total) %></span>
        </div>

        <% if (carts.length > 0) { %>
          <form action="/buyer/checkout" method="POST">
            <input type="hidden" name="buyerId" value="<%= buyerId %>">
            <button type="submit" class="btn btn-dark w-100 btn-checkout">
              <i class="bi bi-bag-check me-2"></i>Konfirmasi & Checkout
            </button>
          </form>
        <% } else { %>
          <button class="btn btn-secondary w-100 btn-checkout" disabled>
            <i class="bi bi-bag-check me-2"></i>Konfirmasi & Checkout
          </button>
        <% } %>

      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
